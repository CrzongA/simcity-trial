# Create a copy of this file named .env (or just use this if you rename it)
# and paste your API key below.

# If you are using a Cesium Ion token that has Google Photorealistic 3D Tiles enabled:
VITE_CESIUM_ION_TOKEN=your_cesium_ion_token_here

# Alternatively, if you want to use a direct Google Maps API Key for the tiles:
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
